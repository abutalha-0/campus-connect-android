<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/color_background">

    <include layout="@layout/top_bar_edit" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/color_border" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView style="@style/FacultyFieldLabel" android:text="@string/notice_label_text" />
            <EditText
                android:id="@+id/etText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="96dp"
                android:gravity="top|start"
                android:background="@drawable/bg_input"
                android:padding="14dp"
                android:inputType="textMultiLine|textCapSentences"
                android:hint="@string/notice_hint_text"
                android:textColor="@color/color_text_primary"
                android:textSize="14sp"
                android:layout_marginBottom="16dp" />

            <CheckBox
                android:id="@+id/cbHighlight"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/notice_highlight_toggle"
                android:textColor="@color/color_text_body"
                android:textSize="12.5sp"
                android:buttonTint="@color/color_cyan"
                android:layout_marginBottom="8dp" />

            <EditText
                android:id="@+id/etHighlight"
                style="@style/FacultyInput"
                android:inputType="text"
                android:hint="@string/notice_hint_highlight"
                android:visibility="gone" />

            <!-- Structured date/time, independent of the free-text highlight
                 above. Setting either is enough to trigger the callout. -->
            <CheckBox
                android:id="@+id/cbDate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/notice_date_toggle"
                android:textColor="@color/color_text_body"
                android:textSize="12.5sp"
                android:buttonTint="@color/color_cyan"
                android:layout_marginBottom="8dp" />

            <LinearLayout
                android:id="@+id/dateTimeRow"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:visibility="gone"
                android:layout_marginBottom="16dp">

                <TextView
                    android:id="@+id/btnPickDate"
                    android:layout_width="0dp"
                    android:layout_height="52dp"
                    android:layout_weight="1"
                    android:gravity="center_vertical"
                    android:background="@drawable/bg_input"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:text="@string/notice_pick_date"
                    android:textColor="@color/color_muted"
                    android:textSize="13.5sp"
                    android:maxLines="1"
                    android:ellipsize="end" />

                <TextView
                    android:id="@+id/btnPickTime"
                    android:layout_width="0dp"
                    android:layout_height="52dp"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:gravity="center_vertical"
                    android:background="@drawable/bg_input"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:text="@string/notice_pick_time"
                    android:textColor="@color/color_muted"
                    android:textSize="13.5sp"
                    android:maxLines="1"
                    android:ellipsize="end" />
            </LinearLayout>

            <TextView style="@style/FacultyFieldLabel" android:text="@string/notice_label_attachment" />
            <TextView
                android:id="@+id/btnPickFile"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:gravity="center_vertical"
                android:background="@drawable/bg_input"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:text="@string/resource_attach_file"
                android:textColor="@color/color_muted"
                android:textSize="14sp"
                android:maxLines="1"
                android:ellipsize="end"
                android:layout_marginBottom="20dp" />

            <TextView
                android:id="@+id/btnSaveNotice"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:gravity="center"
                android:text="Save"
                android:textColor="@color/color_background"
                android:textSize="14sp"
                android:textStyle="bold"
                android:background="@drawable/bg_button_primary" />

        </LinearLayout>
    </ScrollView>

</LinearLayout>
