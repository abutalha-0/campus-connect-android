<?xml version="1.0" encoding="utf-8"?>
<!--
    bottom_sheet_add_project.xml  (CORRECTED)
    ───────────────────────────────────────────
    CHANGED: the "URL" field block was removed entirely.
    The API (POST /api/profiles/me/projects/) only accepts:
    name, description, associated_with. There is no url field on this
    endpoint, so collecting one was misleading to the user.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_bottom_sheet"
    android:paddingBottom="32dp">

    <!-- Drag handle -->
    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="4dp"
        android:background="#3A4560"/>

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp">

        <TextView
            android:id="@+id/tvSheetTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Add Project"
            android:textColor="@color/color_text_primary"
            android:textSize="16sp"
            android:textStyle="bold"/>

        <TextView
            android:id="@+id/btnSave"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Add"
            android:textColor="@color/color_cyan"
            android:textSize="14sp"
            android:textStyle="bold"
            android:padding="8dp"/>

    </LinearLayout>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/color_border"
        android:layout_marginBottom="20dp"/>

    <!-- Fields -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingEnd="20dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Project Name"
                android:textColor="@color/color_muted"
                android:textSize="11sp"
                android:textAllCaps="true"
                android:letterSpacing="0.08"
                android:layout_marginBottom="6dp"/>

            <EditText
                android:id="@+id/etProjectName"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:background="@drawable/bg_input_selector"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:inputType="text"
                android:hint="e.g. Campus Connect"
                android:textColor="@color/color_text_primary"
                android:textColorHint="@color/color_muted"
                android:textSize="14sp"
                android:layout_marginBottom="20dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Associated With"
                android:textColor="@color/color_muted"
                android:textSize="11sp"
                android:textAllCaps="true"
                android:letterSpacing="0.08"
                android:layout_marginBottom="6dp"/>

            <EditText
                android:id="@+id/etAssociatedWith"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:background="@drawable/bg_input_selector"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:inputType="text"
                android:hint="e.g. University, Company (optional)"
                android:textColor="@color/color_text_primary"
                android:textColorHint="@color/color_muted"
                android:textSize="14sp"
                android:layout_marginBottom="20dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Description"
                android:textColor="@color/color_muted"
                android:textSize="11sp"
                android:textAllCaps="true"
                android:letterSpacing="0.08"
                android:layout_marginBottom="6dp"/>

            <EditText
                android:id="@+id/etDescription"
                android:layout_width="match_parent"
                android:layout_height="100dp"
                android:background="@drawable/bg_input_selector"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="12dp"
                android:paddingBottom="12dp"
                android:inputType="textMultiLine"
                android:gravity="top"
                android:hint="What does this project do? (optional)"
                android:textColor="@color/color_text_primary"
                android:textColorHint="@color/color_muted"
                android:textSize="14sp"
                android:layout_marginBottom="8dp"/>

            <!--
                REMOVED: the URL input block that used to be here.
                (id="etUrl" — no longer exists; do not reference it in Java)
            -->

        </LinearLayout>

    </ScrollView>

</LinearLayout>