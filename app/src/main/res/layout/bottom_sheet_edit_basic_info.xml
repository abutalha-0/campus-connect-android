<?xml version="1.0" encoding="utf-8"?>
<!--
    bottom_sheet_edit_basic_info.xml
    ─────────────────────────────────
    BottomSheetDialogFragment layout for editing bio, about text, and user type.
    Replaces activity_edit_basic_info.xml as the editing surface.

    Visual reference:
      ┌──────────────────────────────┐
      │  ▬▬▬  (drag handle)         │
      │  Edit Info          [Save]   │
      │  ─────────────────────────   │
      │  Bio                         │
      │  [ Short tagline... ]        │
      │  About                       │
      │  [ Tell others...   ]        │
      │  User Type                   │
      │  [ ● Student      ]          │
      │  [ ○ Class Rep    ]          │
      └──────────────────────────────┘
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_bottom_sheet"
    android:paddingBottom="32dp">

    <!-- Drag handle -->
    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="4dp"
        android:background="#3A4560"
        android:layerType="none"/>

    <!-- Sheet header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Edit Info"
            android:textColor="@color/color_text_primary"
            android:textSize="16sp"
            android:textStyle="bold"/>

        <!-- Save button -->
        <TextView
            android:id="@+id/btnSave"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Save"
            android:textColor="@color/color_cyan"
            android:textSize="14sp"
            android:textStyle="bold"
            android:padding="8dp"/>

    </LinearLayout>

    <!-- Thin divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/color_border"
        android:layout_marginBottom="20dp"/>

    <!-- Scrollable fields -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingEnd="20dp">

            <!-- Bio label -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Bio"
                android:textColor="@color/color_muted"
                android:textSize="11sp"
                android:textAllCaps="true"
                android:letterSpacing="0.08"
                android:layout_marginBottom="6dp"/>

            <!-- Bio input -->
            <EditText
                android:id="@+id/etBio"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:background="@drawable/bg_input_selector"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:inputType="text"
                android:hint="Short tagline (max 160 chars)"
                android:textColor="@color/color_text_primary"
                android:textColorHint="@color/color_muted"
                android:textSize="14sp"
                android:maxLength="160"
                android:layout_marginBottom="20dp"/>

            <!-- About label -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="About"
                android:textColor="@color/color_muted"
                android:textSize="11sp"
                android:textAllCaps="true"
                android:letterSpacing="0.08"
                android:layout_marginBottom="6dp"/>

            <!-- About input -->
            <EditText
                android:id="@+id/etAbout"
                android:layout_width="match_parent"
                android:layout_height="120dp"
                android:background="@drawable/bg_input_selector"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="12dp"
                android:paddingBottom="12dp"
                android:inputType="textMultiLine"
                android:gravity="top"
                android:hint="Tell others about yourself"
                android:textColor="@color/color_text_primary"
                android:textColorHint="@color/color_muted"
                android:textSize="14sp"
                android:layout_marginBottom="20dp"/>

            <!-- User Type label -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="User Type"
                android:textColor="@color/color_muted"
                android:textSize="11sp"
                android:textAllCaps="true"
                android:letterSpacing="0.08"
                android:layout_marginBottom="6dp"/>

            <!-- STUDENT option row -->
            <LinearLayout
                android:id="@+id/optionStudent"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_input"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:layout_marginBottom="8dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Student"
                    android:textColor="@color/color_text_primary"
                    android:textSize="14sp"/>

                <TextView
                    android:id="@+id/checkStudent"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="○"
                    android:textColor="@color/color_muted"
                    android:textSize="18sp"/>

            </LinearLayout>

            <!-- CR option row -->
            <LinearLayout
                android:id="@+id/optionCR"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_input"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:layout_marginBottom="8dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Class Representative (CR)"
                    android:textColor="@color/color_text_primary"
                    android:textSize="14sp"/>

                <TextView
                    android:id="@+id/checkCR"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="○"
                    android:textColor="@color/color_muted"
                    android:textSize="18sp"/>

            </LinearLayout>

        </LinearLayout>

    </ScrollView>

</LinearLayout>