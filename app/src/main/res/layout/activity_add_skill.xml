<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/color_background">

    <include layout="@layout/top_bar_edit"/>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/color_border"/>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Your Skills"
                android:textColor="@color/color_muted"
                android:textSize="11sp"
                android:textAllCaps="true"
                android:letterSpacing="0.08"
                android:layout_marginBottom="8dp"/>

            <com.google.android.material.chip.ChipGroup
                android:id="@+id/currentSkillsChipGroup"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                app:chipSpacingHorizontal="6dp"
                app:chipSpacingVertical="6dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Add a Skill"
                android:textColor="@color/color_muted"
                android:textSize="11sp"
                android:textAllCaps="true"
                android:letterSpacing="0.08"
                android:layout_marginBottom="6dp"/>

            <EditText
                android:id="@+id/etSkillSearch"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:background="@drawable/bg_input_selector"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:inputType="text|textNoSuggestions"
                android:imeOptions="actionDone"
                android:hint="Search or type a new skill…"
                android:textColor="@color/color_text_primary"
                android:textColorHint="@color/color_muted"
                android:textSize="14sp"
                android:layout_marginBottom="12dp"/>

            <com.google.android.material.chip.ChipGroup
                android:id="@+id/skillCatalogChipGroup"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:singleSelection="true"
                android:layout_marginBottom="16dp"
                app:chipSpacingHorizontal="6dp"
                app:chipSpacingVertical="6dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="32dp"
                android:orientation="horizontal"
                android:layout_marginBottom="16dp">

                <TextView
                    android:id="@+id/tvProfBeginner"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:layout_marginEnd="3dp"
                    android:gravity="center"
                    android:text="Beginner"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:background="@drawable/bg_tab_pill_active"
                    android:textColor="@color/color_cyan"/>

                <TextView
                    android:id="@+id/tvProfIntermediate"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:layout_marginStart="3dp"
                    android:layout_marginEnd="3dp"
                    android:gravity="center"
                    android:text="Intermediate"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:background="@drawable/bg_tab_pill_inactive"
                    android:textColor="@color/color_muted"/>

                <TextView
                    android:id="@+id/tvProfAdvanced"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:layout_marginStart="3dp"
                    android:gravity="center"
                    android:text="Advanced"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:background="@drawable/bg_tab_pill_inactive"
                    android:textColor="@color/color_muted"/>

            </LinearLayout>

            <TextView
                android:id="@+id/btnAddSkill"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:gravity="center"
                android:text="+ Add Skill"
                android:textColor="@color/color_background"
                android:textSize="14sp"
                android:textStyle="bold"
                android:background="@drawable/bg_button_primary"/>

        </LinearLayout>

    </ScrollView>

</LinearLayout>
