<?xml version="1.0" encoding="utf-8"?>
<!--
    PublicProfileActivity Layout
    ────────────────────────────
    Read-only view of another user's profile.
    Same structure as fragment_profile.xml with two differences:
    1. Back button instead of logout button
    2. No edit controls anywhere
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/color_background"
    android:clipChildren="false"
    android:clipToPadding="false">

    <!-- ─── TOP BAR ─────────────────────────────────────────────────────── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:background="@color/color_background">

        <!-- Back button -->
        <TextView
            android:id="@+id/btnBack"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="← Back"
            android:textColor="@color/color_cyan"
            android:textSize="14sp"
            android:padding="8dp"/>

        <!-- Screen title -->
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Profile"
            android:textColor="@color/color_text_primary"
            android:textSize="18sp"
            android:textStyle="bold"
            android:gravity="center"/>

        <!-- Spacer to balance back button -->
        <View
            android:layout_width="60dp"
            android:layout_height="wrap_content"/>

    </LinearLayout>

    <!-- ─── SCROLLABLE CONTENT ───────────────────────────────────────────── -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipChildren="false"
        android:clipToPadding="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:clipChildren="false"
            android:clipToPadding="false">

            <!-- ─── COVER BANNER ─────────────────────────────────────────── -->
            <View
                android:id="@+id/coverBanner"
                android:layout_width="match_parent"
                android:layout_height="100dp"/>

            <!-- ─── HERO CARD ─────────────────────────────────────────────── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:layout_marginTop="-32dp"
                android:clipChildren="false"
                android:clipToPadding="false">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@drawable/bg_card"
                    android:padding="16dp"
                    android:clipChildren="false"
                    android:clipToPadding="false">

                    <!-- Avatar row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:clipChildren="false"
                        android:clipToPadding="false">

                        <FrameLayout
                            android:layout_width="72dp"
                            android:layout_height="72dp"
                            android:layout_marginTop="-28dp"
                            android:clipChildren="false"
                            android:clipToPadding="false">

                            <ImageView
                                android:id="@+id/ivAvatar"
                                android:layout_width="72dp"
                                android:layout_height="72dp"
                                android:background="@drawable/bg_avatar_large"
                                android:scaleType="centerCrop"
                                android:clipToOutline="true"
                                android:src="@android:drawable/ic_menu_myplaces"/>

                        </FrameLayout>

                        <View
                            android:layout_width="0dp"
                            android:layout_height="1dp"
                            android:layout_weight="1"/>

                    </LinearLayout>

                    <!-- Full name -->
                    <TextView
                        android:id="@+id/tvFullName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/color_text_primary"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:layout_marginTop="10dp"/>

                    <!-- Username -->
                    <TextView
                        android:id="@+id/tvUsername"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/color_cyan"
                        android:textSize="13sp"
                        android:layout_marginTop="2dp"/>

                    <!-- User type badge -->
                    <TextView
                        android:id="@+id/tvUserType"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_badge"
                        android:textColor="@color/color_cyan"
                        android:textSize="11sp"
                        android:paddingStart="10dp"
                        android:paddingEnd="10dp"
                        android:paddingTop="4dp"
                        android:paddingBottom="4dp"
                        android:layout_marginTop="8dp"/>

                </LinearLayout>

            </LinearLayout>

            <!-- ─── ABOUT SECTION ─────────────────────────────────────────── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_card"
                android:padding="16dp"
                android:layout_marginTop="10dp"
                android:layout_marginStart="12dp"
                android:layout_marginEnd="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ABOUT"
                    android:textColor="@color/color_muted"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.1"
                    android:layout_marginBottom="8dp"/>

                <TextView
                    android:id="@+id/tvAbout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/color_text_body"
                    android:textSize="14sp"
                    android:lineSpacingMultiplier="1.5"/>

            </LinearLayout>

            <!-- ─── TAB SECTION ───────────────────────────────────────────── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="10dp"
                android:layout_marginStart="12dp"
                android:layout_marginEnd="12dp"
                android:layout_marginBottom="24dp">

                <!-- Tab buttons -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:orientation="horizontal"
                    android:background="@drawable/bg_card"
                    android:padding="4dp">

                    <TextView
                        android:id="@+id/tabProjects"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:text="Projects"
                        android:textSize="12sp"
                        android:textStyle="bold"/>

                    <TextView
                        android:id="@+id/tabExperience"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:text="Experience"
                        android:textSize="12sp"
                        android:textStyle="bold"/>

                    <TextView
                        android:id="@+id/tabEducation"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:text="Education"
                        android:textSize="12sp"
                        android:textStyle="bold"/>

                </LinearLayout>

                <!-- Tab content populated dynamically -->
                <LinearLayout
                    android:id="@+id/tabContent"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginTop="10dp"/>

            </LinearLayout>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

</LinearLayout>