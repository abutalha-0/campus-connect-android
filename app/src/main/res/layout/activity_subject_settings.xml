<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/color_background">

    <include layout="@layout/top_bar_edit" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/color_border" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Share code card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center_horizontal"
                android:background="@drawable/bg_info_banner"
                android:padding="18dp"
                android:layout_marginBottom="22dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/subject_code_label"
                    android:textColor="@color/color_muted"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.1" />

                <TextView
                    android:id="@+id/tvCode"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:letterSpacing="0.3"
                    android:textColor="@color/color_cyan"
                    android:textSize="28sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:gravity="center"
                    android:text="@string/subject_code_note"
                    android:textColor="@color/color_muted"
                    android:textSize="11sp"
                    android:lineSpacingMultiplier="1.4" />

                <TextView
                    android:id="@+id/btnCopyCode"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/bg_button_outline"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:paddingTop="7dp"
                    android:paddingBottom="7dp"
                    android:text="@string/subject_copy"
                    android:textColor="@color/color_text_primary"
                    android:textSize="12sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Edit fields -->
            <TextView style="@style/FacultyFieldLabel" android:text="@string/subject_label_name" />
            <EditText
                android:id="@+id/etName"
                style="@style/FacultyInput"
                android:inputType="textCapWords"
                android:hint="@string/subject_hint_name" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:baselineAligned="false">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginEnd="6dp">

                    <TextView style="@style/FacultyFieldLabel" android:text="@string/subject_label_intake" />
                    <EditText
                        android:id="@+id/etIntake"
                        style="@style/FacultyInput"
                        android:inputType="text"
                        android:hint="@string/subject_hint_intake" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="6dp">

                    <TextView style="@style/FacultyFieldLabel" android:text="@string/subject_label_section" />
                    <EditText
                        android:id="@+id/etSection"
                        style="@style/FacultyInput"
                        android:inputType="textCapCharacters"
                        android:hint="@string/subject_hint_section" />
                </LinearLayout>
            </LinearLayout>

            <TextView style="@style/FacultyFieldLabel" android:text="@string/subject_label_room" />
            <EditText
                android:id="@+id/etRoom"
                style="@style/FacultyInput"
                android:inputType="text"
                android:hint="@string/subject_hint_room" />

            <TextView
                android:id="@+id/btnSaveSubject"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:gravity="center"
                android:text="@string/subject_settings_save"
                android:textColor="@color/color_background"
                android:textSize="14sp"
                android:textStyle="bold"
                android:background="@drawable/bg_button_primary"
                android:layout_marginTop="4dp" />

            <TextView
                android:id="@+id/btnDelete"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:gravity="center"
                android:text="@string/subject_delete"
                android:textColor="@color/color_red"
                android:textSize="14sp"
                android:textStyle="bold"
                android:background="@drawable/bg_delete_button"
                android:layout_marginTop="12dp" />

        </LinearLayout>
    </ScrollView>

</LinearLayout>
