<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/color_background">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="20dp"
        android:paddingTop="14dp"
        android:paddingBottom="14dp">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="26dp"
            android:layout_height="26dp"
            android:src="@drawable/ic_chevron_left"
            android:tint="@color/color_text_primary"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true"
            android:contentDescription="@null" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="10dp"
            android:text="@string/classroom_title"
            android:textColor="@color/color_text_primary"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/btnCreateClass"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_button_outline"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:paddingTop="8dp"
            android:paddingBottom="8dp"
            android:text="＋ Create Class"
            android:textColor="@color/color_text_primary"
            android:textSize="12.5sp"
            android:textStyle="bold" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <!-- ── Empty state: Join ── -->
            <LinearLayout
                android:id="@+id/emptyState"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center_horizontal"
                android:paddingStart="28dp"
                android:paddingEnd="28dp"
                android:paddingTop="60dp"
                android:visibility="gone">

                <View
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    android:background="@drawable/bg_avatar_gradient" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="@string/join_title"
                    android:textColor="@color/color_text_primary"
                    android:textSize="19sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="@string/join_subtitle"
                    android:textColor="@color/color_muted"
                    android:textSize="13sp"
                    android:gravity="center" />

                <EditText
                    android:id="@+id/etJoinCode"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:layout_marginTop="24dp"
                    android:background="@drawable/bg_input"
                    android:gravity="center"
                    android:inputType="textCapCharacters"
                    android:hint="@string/join_hint"
                    android:textColor="@color/color_text_primary"
                    android:textSize="15sp"
                    android:letterSpacing="0.1" />

                <TextView
                    android:id="@+id/btnJoinSubmit"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:layout_marginTop="18dp"
                    android:gravity="center"
                    android:text="@string/join_submit"
                    android:textColor="@color/color_background"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:background="@drawable/bg_button_primary" />
            </LinearLayout>

            <!-- ── Class state ── -->
            <LinearLayout
                android:id="@+id/classState"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:paddingBottom="24dp"
                android:visibility="gone">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_warning_banner"
                    android:padding="12dp"
                    android:text="@string/class_one_at_a_time"
                    android:textColor="#FBBF24"
                    android:textSize="11.5sp"
                    android:lineSpacingMultiplier="1.4"
                    android:layout_marginBottom="16dp" />

                <!-- Class code card -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center_horizontal"
                    android:background="@drawable/bg_card"
                    android:padding="20dp"
                    android:layout_marginBottom="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/class_code_heading"
                        android:textColor="@color/color_muted"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.15" />

                    <TextView
                        android:id="@+id/tvClassCode"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:letterSpacing="0.35"
                        android:textColor="@color/color_cyan"
                        android:textSize="30sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/btnCopyCode"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:background="@drawable/bg_button_outline"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"
                        android:paddingTop="7dp"
                        android:paddingBottom="7dp"
                        android:text="@string/subject_copy"
                        android:textColor="@color/color_text_primary"
                        android:textSize="12sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/class_courses_heading"
                    android:textColor="@color/color_muted"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.1"
                    android:layout_marginBottom="10dp" />

                <LinearLayout
                    android:id="@+id/coursesContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical" />

                <!-- Add-course row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="4dp">

                    <EditText
                        android:id="@+id/etAddCode"
                        android:layout_width="0dp"
                        android:layout_height="52dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_input"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:inputType="number"
                        android:hint="@string/class_add_course_hint"
                        android:textColor="@color/color_text_primary"
                        android:textSize="14sp"
                        android:letterSpacing="0.05" />

                    <TextView
                        android:id="@+id/btnAddCourse"
                        android:layout_width="52dp"
                        android:layout_height="52dp"
                        android:layout_marginStart="8dp"
                        android:gravity="center"
                        android:text="＋"
                        android:textColor="@color/color_background"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:background="@drawable/bg_button_primary" />
                </LinearLayout>

                <TextView
                    android:id="@+id/btnDeleteClass"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="22dp"
                    android:gravity="center"
                    android:text="@string/class_delete"
                    android:textColor="@color/color_red"
                    android:textSize="13.5sp"
                    android:textStyle="bold"
                    android:background="@drawable/bg_delete_button" />
            </LinearLayout>
        </FrameLayout>
    </ScrollView>

</LinearLayout>
