<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/color_background">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="20dp"
        android:paddingTop="14dp"
        android:paddingBottom="14dp">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="26dp"
            android:layout_height="26dp"
            android:src="@drawable/ic_chevron_left"
            android:tint="@color/color_text_primary"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true"
            android:contentDescription="@null" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="10dp">

            <TextView
                android:id="@+id/tvHeaderTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/classroom_title"
                android:textColor="@color/color_text_primary"
                android:textSize="20sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvHeaderCode"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="1dp"
                android:textColor="@color/color_muted"
                android:textSize="12sp"
                android:visibility="gone" />
        </LinearLayout>

        <TextView
            android:id="@+id/btnCreateClass"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_button_outline"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:paddingTop="8dp"
            android:paddingBottom="8dp"
            android:text="＋ Create Class"
            android:textColor="@color/color_text_primary"
            android:textSize="12.5sp"
            android:textStyle="bold" />

        <ImageView
            android:id="@+id/btnSettings"
            android:layout_width="38dp"
            android:layout_height="38dp"
            android:padding="9dp"
            android:src="@drawable/ic_settings"
            android:tint="@color/color_text_primary"
            android:background="@drawable/bg_button_outline"
            android:clickable="true"
            android:focusable="true"
            android:contentDescription="@null"
            android:visibility="gone" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <!-- ── Empty state: Join ── -->
            <LinearLayout
                android:id="@+id/emptyState"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center_horizontal"
                android:paddingStart="28dp"
                android:paddingEnd="28dp"
                android:paddingTop="60dp"
                android:visibility="gone">

                <View
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    android:background="@drawable/bg_avatar_gradient" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="@string/join_title"
                    android:textColor="@color/color_text_primary"
                    android:textSize="19sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="@string/join_subtitle"
                    android:textColor="@color/color_muted"
                    android:textSize="13sp"
                    android:gravity="center" />

                <EditText
                    android:id="@+id/etJoinCode"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:layout_marginTop="24dp"
                    android:background="@drawable/bg_input"
                    android:gravity="center"
                    android:inputType="textCapCharacters"
                    android:hint="@string/join_hint"
                    android:textColor="@color/color_text_primary"
                    android:textSize="15sp"
                    android:letterSpacing="0.1" />

                <TextView
                    android:id="@+id/btnJoinSubmit"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:layout_marginTop="18dp"
                    android:gravity="center"
                    android:text="@string/join_submit"
                    android:textColor="@color/color_background"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:background="@drawable/bg_button_primary" />
            </LinearLayout>

            <!-- ── Class state: subjects list ── -->
            <LinearLayout
                android:id="@+id/classState"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="18dp"
                android:paddingEnd="18dp"
                android:paddingTop="4dp"
                android:paddingBottom="24dp"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="34dp"
                    android:orientation="horizontal"
                    android:layout_marginBottom="16dp">

                    <TextView
                        android:id="@+id/tabSubjects"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:layout_marginEnd="4dp"
                        android:gravity="center"
                        android:text="@string/tab_subjects"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:background="@drawable/bg_tab_pill_active"
                        android:textColor="@color/color_cyan" />

                    <TextView
                        android:id="@+id/tabSchedule"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:layout_marginStart="4dp"
                        android:layout_marginEnd="4dp"
                        android:gravity="center"
                        android:text="@string/tab_schedule"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:background="@drawable/bg_tab_pill_inactive"
                        android:textColor="@color/color_muted" />

                    <TextView
                        android:id="@+id/tabFeed"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:layout_marginStart="4dp"
                        android:gravity="center"
                        android:text="@string/tab_feed"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:background="@drawable/bg_tab_pill_inactive"
                        android:textColor="@color/color_muted" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/subjectsContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical" />
            </LinearLayout>
        </FrameLayout>
    </ScrollView>

</LinearLayout>
