<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/color_background">

    <include layout="@layout/top_bar_edit" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/color_border" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView style="@style/FacultyFieldLabel" android:text="@string/resource_label_title" />
            <EditText
                android:id="@+id/etTitle"
                style="@style/FacultyInput"
                android:inputType="text"
                android:hint="@string/resource_hint_title" />

            <TextView style="@style/FacultyFieldLabel" android:text="@string/resource_label_type" />
            <Spinner
                android:id="@+id/spinnerType"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:background="@drawable/bg_input"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:popupBackground="@color/color_card"
                android:layout_marginBottom="16dp" />

            <TextView style="@style/FacultyFieldLabel" android:text="@string/resource_label_desc" />
            <EditText
                android:id="@+id/etDescription"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="72dp"
                android:gravity="top|start"
                android:background="@drawable/bg_input"
                android:padding="14dp"
                android:inputType="textMultiLine"
                android:hint="@string/resource_hint_desc"
                android:textColor="@color/color_text_primary"
                android:textSize="14sp"
                android:layout_marginBottom="16dp" />

            <!-- File attachment (documents) -->
            <LinearLayout
                android:id="@+id/filePickerRow"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView style="@style/FacultyFieldLabel" android:text="@string/resource_label_attachment" />
                <TextView
                    android:id="@+id/btnPickFile"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:gravity="center_vertical"
                    android:background="@drawable/bg_input"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:text="@string/resource_attach_file"
                    android:textColor="@color/color_muted"
                    android:textSize="14sp"
                    android:maxLines="1"
                    android:ellipsize="end"
                    android:layout_marginBottom="20dp" />
            </LinearLayout>

            <!-- Video link (shown when Type = Video) -->
            <LinearLayout
                android:id="@+id/videoLinkRow"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView style="@style/FacultyFieldLabel" android:text="@string/resource_label_link" />
                <EditText
                    android:id="@+id/etVideoLink"
                    style="@style/FacultyInput"
                    android:inputType="textUri"
                    android:hint="@string/resource_hint_link" />
            </LinearLayout>

            <TextView
                android:id="@+id/btnSaveResource"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:gravity="center"
                android:text="Save"
                android:textColor="@color/color_background"
                android:textSize="14sp"
                android:textStyle="bold"
                android:background="@drawable/bg_button_primary" />

        </LinearLayout>
    </ScrollView>

</LinearLayout>
