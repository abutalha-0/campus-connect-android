<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/color_background">

    <include layout="@layout/top_bar_edit"/>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/color_border"/>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- About-card fields: hidden entirely when opened from the hero card -->
            <LinearLayout
                android:id="@+id/groupAboutFields"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Bio"
                    android:textColor="@color/color_muted"
                    android:textSize="11sp"
                    android:textAllCaps="true"
                    android:letterSpacing="0.08"
                    android:layout_marginBottom="6dp"/>

                <EditText
                    android:id="@+id/etBio"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:background="@drawable/bg_input_selector"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:inputType="text"
                    android:hint="Short tagline (max 160 chars)"
                    android:textColor="@color/color_text_primary"
                    android:textColorHint="@color/color_muted"
                    android:textSize="14sp"
                    android:maxLength="160"
                    android:layout_marginBottom="20dp"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="About"
                    android:textColor="@color/color_muted"
                    android:textSize="11sp"
                    android:textAllCaps="true"
                    android:letterSpacing="0.08"
                    android:layout_marginBottom="6dp"/>

                <EditText
                    android:id="@+id/etAbout"
                    android:layout_width="match_parent"
                    android:layout_height="120dp"
                    android:background="@drawable/bg_input_selector"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:paddingTop="12dp"
                    android:paddingBottom="12dp"
                    android:inputType="textMultiLine"
                    android:gravity="top"
                    android:hint="Tell others about yourself"
                    android:textColor="@color/color_text_primary"
                    android:textColorHint="@color/color_muted"
                    android:textSize="14sp"
                    android:layout_marginBottom="20dp"/>

            </LinearLayout>

            <!-- Hero-card field: hidden entirely when opened from the About card -->
            <LinearLayout
                android:id="@+id/groupUserType"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="User Type"
                    android:textColor="@color/color_muted"
                    android:textSize="11sp"
                    android:textAllCaps="true"
                    android:letterSpacing="0.08"
                    android:layout_marginBottom="6dp"/>

                <LinearLayout
                    android:id="@+id/optionStudent"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@drawable/bg_input"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:layout_marginBottom="8dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Student"
                        android:textColor="@color/color_text_primary"
                        android:textSize="14sp"/>

                    <TextView
                        android:id="@+id/checkStudent"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="○"
                        android:textColor="@color/color_muted"
                        android:textSize="18sp"/>

                </LinearLayout>

                <LinearLayout
                    android:id="@+id/optionCR"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@drawable/bg_input"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:layout_marginBottom="8dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Class Representative (CR)"
                        android:textColor="@color/color_text_primary"
                        android:textSize="14sp"/>

                    <TextView
                        android:id="@+id/checkCR"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="○"
                        android:textColor="@color/color_muted"
                        android:textSize="18sp"/>

                </LinearLayout>

            </LinearLayout>

        </LinearLayout>

    </ScrollView>

</LinearLayout>
