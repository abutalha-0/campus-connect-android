<?xml version="1.0" encoding="utf-8"?>
<!--
    FrameLayout root so the ViewPager2 is always the full screen — skip
    button and dots/controls are overlaid on top of it, not stacked as
    weighted siblings. (A LinearLayout+weight version shrank the pager every
    time inset padding was added to the chrome rows, since growing a sibling
    steals space from the weighted view.)
-->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/color_background"
    android:fitsSystemWindows="false">

    <!-- ─── SWIPEABLE CONTENT — always fills the entire screen ────────────── -->
    <androidx.viewpager2.widget.ViewPager2
        android:id="@+id/viewPager"
        android:layout_width="match_parent"
        android:layout_height="match_parent"/>

    <!-- ─── SKIP ROW (overlay, top) ─────────────────────────────────────── -->
    <LinearLayout
        android:id="@+id/topBarRow"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="top"
        android:gravity="end"
        android:paddingTop="18dp"
        android:paddingEnd="22dp">

        <TextView
            android:id="@+id/btnSkip"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:padding="6dp"
            android:text="Skip"
            android:textColor="#80FFFFFF"
            android:textSize="13sp"
            android:textStyle="bold"/>

    </LinearLayout>

    <!-- ─── DOTS + BOTTOM CONTROLS (overlay, bottom) ───────────────────────── -->
    <LinearLayout
        android:id="@+id/bottomChrome"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:orientation="vertical">

        <!-- Step dots -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:paddingBottom="24dp">

            <View
                android:id="@+id/dot0"
                android:layout_width="22dp"
                android:layout_height="8dp"
                android:layout_marginEnd="8dp"
                android:background="@drawable/bg_onboarding_dot"/>

            <View
                android:id="@+id/dot1"
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:layout_marginEnd="8dp"
                android:background="@drawable/bg_onboarding_dot"/>

            <View
                android:id="@+id/dot2"
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:layout_marginEnd="8dp"
                android:background="@drawable/bg_onboarding_dot"/>

            <View
                android:id="@+id/dot3"
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:background="@drawable/bg_onboarding_dot"/>

        </LinearLayout>

        <!-- Back + Next/Get Started -->
        <LinearLayout
            android:id="@+id/bottomControlsRow"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="22dp"
            android:paddingEnd="22dp"
            android:paddingBottom="34dp">

            <ImageButton
                android:id="@+id/btnBack"
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:layout_marginEnd="10dp"
                android:background="@drawable/bg_onboarding_back_button"
                android:src="@drawable/ic_chevron_left"
                android:padding="17dp"
                android:visibility="gone"
                android:contentDescription="@null"/>

            <TextView
                android:id="@+id/btnNext"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:gravity="center"
                android:textColor="@color/color_background"
                android:textSize="15sp"
                android:textStyle="bold"
                android:text="Next"/>

        </LinearLayout>

    </LinearLayout>

</FrameLayout>
