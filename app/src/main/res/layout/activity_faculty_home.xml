<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/color_background">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="14dp"
        android:paddingBottom="12dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="My Profile"
            android:textColor="@color/color_text_primary"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/btnLogout"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_button_outline"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:paddingTop="7dp"
            android:paddingBottom="7dp"
            android:text="@string/btn_logout"
            android:textColor="@color/color_muted"
            android:textSize="11sp"
            android:textStyle="bold" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingBottom="24dp">

            <!-- Not-verified banner (shown only for unverified accounts) -->
            <TextView
                android:id="@+id/tvNotVerifiedBanner"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_error_banner"
                android:padding="12dp"
                android:text="@string/faculty_not_verified_banner"
                android:textColor="@color/color_red"
                android:textSize="12sp"
                android:textStyle="bold"
                android:lineSpacingMultiplier="1.35"
                android:layout_marginBottom="12dp"
                android:visibility="gone" />

            <!-- Profile card -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_card"
                android:padding="22dp">

                <TextView
                    android:id="@+id/btnEditIdentity"
                    android:layout_width="30dp"
                    android:layout_height="30dp"
                    android:layout_alignParentEnd="true"
                    android:background="@drawable/bg_button_outline"
                    android:gravity="center"
                    android:text="✎"
                    android:textColor="@color/color_muted"
                    android:textSize="13sp" />

                <FrameLayout
                    android:id="@+id/avatarFrame"
                    android:layout_width="76dp"
                    android:layout_height="76dp"
                    android:layout_centerHorizontal="true">

                    <TextView
                        android:id="@+id/tvAvatarInitials"
                        android:layout_width="76dp"
                        android:layout_height="76dp"
                        android:background="@drawable/bg_avatar_gradient"
                        android:gravity="center"
                        android:textColor="#04121A"
                        android:textSize="24sp"
                        android:textStyle="bold" />

                    <de.hdodenhof.circleimageview.CircleImageView
                        android:id="@+id/ivAvatar"
                        android:layout_width="76dp"
                        android:layout_height="76dp"
                        android:visibility="gone"
                        android:scaleType="centerCrop" />

                    <TextView
                        android:id="@+id/btnChangePhoto"
                        android:layout_width="26dp"
                        android:layout_height="26dp"
                        android:layout_gravity="bottom|end"
                        android:background="@drawable/bg_camera_badge"
                        android:gravity="center"
                        android:text="✎"
                        android:textColor="#04121A"
                        android:textSize="11sp" />
                </FrameLayout>

                <TextView
                    android:id="@+id/tvName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_below="@id/avatarFrame"
                    android:layout_marginTop="14dp"
                    android:gravity="center"
                    android:textColor="@color/color_text_primary"
                    android:textSize="19sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvDesignation"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_below="@id/tvName"
                    android:layout_marginTop="3dp"
                    android:gravity="center"
                    android:textColor="@color/color_cyan"
                    android:textSize="13sp" />
            </RelativeLayout>

            <!-- Contact & Links card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_card"
                android:padding="16dp"
                android:layout_marginTop="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="8dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="CONTACT &amp; LINKS"
                        android:textColor="@color/color_muted"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.08" />

                    <TextView
                        android:id="@+id/btnEditContact"
                        android:layout_width="26dp"
                        android:layout_height="26dp"
                        android:background="@drawable/bg_button_outline"
                        android:gravity="center"
                        android:text="✎"
                        android:textColor="@color/color_muted"
                        android:textSize="12sp" />
                </LinearLayout>

                <!-- Email row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingTop="6dp"
                    android:paddingBottom="6dp">

                    <TextView
                        android:layout_width="30dp"
                        android:layout_height="30dp"
                        android:background="@drawable/bg_badge"
                        android:gravity="center"
                        android:text="✉"
                        android:textColor="@color/color_muted"
                        android:textSize="13sp" />

                    <TextView
                        android:id="@+id/tvEmail"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="12dp"
                        android:maxLines="1"
                        android:ellipsize="end"
                        android:textColor="@color/color_text_body"
                        android:textSize="13sp" />
                </LinearLayout>

                <!-- Dynamic link rows -->
                <LinearLayout
                    android:id="@+id/linksContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical" />
            </LinearLayout>

            <!-- Subjects Taught divider -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="22dp"
                android:layout_marginBottom="12dp">

                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1"
                    android:background="@color/color_border" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:layout_marginEnd="12dp"
                    android:text="@string/subjects_taught"
                    android:textColor="@color/color_muted"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.08" />

                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1"
                    android:background="@color/color_border" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/subjectsContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />

            <TextView
                android:id="@+id/btnAddSubject"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="6dp"
                android:gravity="center"
                android:text="＋  Add"
                android:textColor="@color/color_cyan"
                android:textSize="12sp"
                android:textStyle="bold"
                android:background="@drawable/bg_add_dashed" />

        </LinearLayout>
    </ScrollView>

    <!-- Bottom nav -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@color/color_card"
        android:paddingTop="10dp"
        android:paddingBottom="10dp">

        <LinearLayout
            android:id="@+id/navHome"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_nav_home"
                android:tint="@color/color_muted"
                android:contentDescription="@null" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:text="@string/label_home"
                android:textColor="@color/color_muted"
                android:textSize="11.5sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_nav_profile"
                android:tint="@color/color_cyan"
                android:contentDescription="@null" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:text="@string/label_profile"
                android:textColor="@color/color_cyan"
                android:textSize="11.5sp"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>

</LinearLayout>
