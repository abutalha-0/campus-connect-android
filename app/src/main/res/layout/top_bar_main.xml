<?xml version="1.0" encoding="utf-8"?>
<!--
    Shared top bar for the Home/Discover/Profile bottom-nav tabs:
    hamburger (opens the drawer) + app title + notification bell.
    Not used on PublicProfileActivity — that has its own back-button bar.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="56dp"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingStart="12dp"
    android:paddingEnd="12dp">

    <ImageButton
        android:id="@+id/btnMenu"
        android:layout_width="34dp"
        android:layout_height="34dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:src="@drawable/ic_menu_hamburger"
        android:padding="8dp"
        android:contentDescription="@null"/>

    <TextView
        android:id="@+id/tvAppTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:gravity="center"
        android:text="@string/app_name"
        android:textColor="@color/color_cyan"
        android:textSize="15sp"
        android:textStyle="bold"/>

    <FrameLayout
        android:layout_width="34dp"
        android:layout_height="34dp">

        <ImageButton
            android:id="@+id/btnNotifications"
            android:layout_width="34dp"
            android:layout_height="34dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_bell"
            android:padding="8dp"
            android:contentDescription="@null"/>

        <View
            android:id="@+id/notificationDot"
            android:layout_width="7dp"
            android:layout_height="7dp"
            android:layout_gravity="top|end"
            android:layout_marginTop="5dp"
            android:layout_marginEnd="5dp"
            android:background="@drawable/bg_dot"/>

    </FrameLayout>

</LinearLayout>
