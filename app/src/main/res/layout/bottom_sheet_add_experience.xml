<?xml version="1.0" encoding="utf-8"?>
<!--
    bottom_sheet_add_experience.xml  (CORRECTED)
    ───────────────────────────────────────────────
    CHANGED: Start/End date hints updated from "YYYY-MM" to "YYYY-MM-DD"
    because the API requires full dates (POST /api/profiles/me/experience/).
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_bottom_sheet"
    android:paddingBottom="32dp">

    <!-- Drag handle -->
    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="4dp"
        android:background="#3A4560"/>

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Add Experience"
            android:textColor="@color/color_text_primary"
            android:textSize="16sp"
            android:textStyle="bold"/>

        <TextView
            android:id="@+id/btnSave"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Add"
            android:textColor="@color/color_cyan"
            android:textSize="14sp"
            android:textStyle="bold"
            android:padding="8dp"/>

    </LinearLayout>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/color_border"
        android:layout_marginBottom="20dp"/>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingEnd="20dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Title"
                android:textColor="@color/color_muted"
                android:textSize="11sp"
                android:textAllCaps="true"
                android:letterSpacing="0.08"
                android:layout_marginBottom="6dp"/>

            <EditText
                android:id="@+id/etTitle"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:background="@drawable/bg_input_selector"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:inputType="text"
                android:hint="e.g. Software Engineer Intern"
                android:textColor="@color/color_text_primary"
                android:textColorHint="@color/color_muted"
                android:textSize="14sp"
                android:layout_marginBottom="20dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Organization"
                android:textColor="@color/color_muted"
                android:textSize="11sp"
                android:textAllCaps="true"
                android:letterSpacing="0.08"
                android:layout_marginBottom="6dp"/>

            <EditText
                android:id="@+id/etOrganization"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:background="@drawable/bg_input_selector"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:inputType="text"
                android:hint="e.g. Google, BUET"
                android:textColor="@color/color_text_primary"
                android:textColorHint="@color/color_muted"
                android:textSize="14sp"
                android:layout_marginBottom="20dp"/>

            <!-- Date row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="20dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginEnd="8dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Start Date"
                        android:textColor="@color/color_muted"
                        android:textSize="11sp"
                        android:textAllCaps="true"
                        android:letterSpacing="0.08"
                        android:layout_marginBottom="6dp"/>

                    <!-- CHANGED: hint was "YYYY-MM", now full date -->
                    <EditText
                        android:id="@+id/etStartDate"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:background="@drawable/bg_input_selector"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:inputType="text"
                        android:hint="2024-01-01"
                        android:textColor="@color/color_text_primary"
                        android:textColorHint="@color/color_muted"
                        android:textSize="14sp"/>

                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="8dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="End Date"
                        android:textColor="@color/color_muted"
                        android:textSize="11sp"
                        android:textAllCaps="true"
                        android:letterSpacing="0.08"
                        android:layout_marginBottom="6dp"/>

                    <!-- CHANGED: hint was "or leave blank", now shows the
                         expected format too, since it's still optional -->
                    <EditText
                        android:id="@+id/etEndDate"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:background="@drawable/bg_input_selector"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:inputType="text"
                        android:hint="2024-12-31 (optional)"
                        android:textColor="@color/color_text_primary"
                        android:textColorHint="@color/color_muted"
                        android:textSize="14sp"/>

                </LinearLayout>

            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Description"
                android:textColor="@color/color_muted"
                android:textSize="11sp"
                android:textAllCaps="true"
                android:letterSpacing="0.08"
                android:layout_marginBottom="6dp"/>

            <EditText
                android:id="@+id/etDescription"
                android:layout_width="match_parent"
                android:layout_height="100dp"
                android:background="@drawable/bg_input_selector"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="12dp"
                android:paddingBottom="12dp"
                android:inputType="textMultiLine"
                android:gravity="top"
                android:hint="What did you do here? (optional)"
                android:textColor="@color/color_text_primary"
                android:textColorHint="@color/color_muted"
                android:textSize="14sp"
                android:layout_marginBottom="8dp"/>

        </LinearLayout>

    </ScrollView>

</LinearLayout>