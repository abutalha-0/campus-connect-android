<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/color_background">

    <include layout="@layout/top_bar_edit" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/color_border" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView style="@style/FacultyFieldLabel" android:text="@string/feed_label_title" />
            <EditText
                android:id="@+id/etTitle"
                style="@style/FacultyInput"
                android:inputType="textCapSentences"
                android:hint="@string/feed_hint_title" />

            <TextView style="@style/FacultyFieldLabel" android:text="@string/feed_label_body" />
            <EditText
                android:id="@+id/etBody"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="120dp"
                android:gravity="top|start"
                android:background="@drawable/bg_input"
                android:padding="14dp"
                android:inputType="textMultiLine|textCapSentences"
                android:hint="@string/feed_hint_body"
                android:textColor="@color/color_text_primary"
                android:textSize="14sp"
                android:layout_marginBottom="16dp" />

            <TextView style="@style/FacultyFieldLabel" android:text="@string/feed_label_tag" />
            <Spinner
                android:id="@+id/spinnerTag"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:background="@drawable/bg_input"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:popupBackground="@color/color_card" />

        </LinearLayout>
    </ScrollView>

    <TextView
        android:id="@+id/btnSavePost"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:layout_margin="20dp"
        android:gravity="center"
        android:text="@string/feed_post_btn"
        android:textColor="@color/color_background"
        android:textSize="14.5sp"
        android:textStyle="bold"
        android:background="@drawable/bg_button_primary" />

</LinearLayout>
