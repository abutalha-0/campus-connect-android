<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/color_background">

    <!-- ─── TOP BAR ──────────────────────────────────────────────────────── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="12dp"
        android:paddingEnd="12dp">

        <ImageButton
            android:id="@+id/btnMenu"
            android:layout_width="34dp"
            android:layout_height="34dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_menu_hamburger"
            android:padding="8dp"
            android:contentDescription="@null"/>

        <TextView
            android:id="@+id/tvAppTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="@string/app_name"
            android:textColor="@color/color_cyan"
            android:textSize="15sp"
            android:textStyle="bold"/>

        <FrameLayout
            android:layout_width="34dp"
            android:layout_height="34dp">

            <ImageButton
                android:id="@+id/btnNotifications"
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_bell"
                android:padding="8dp"
                android:contentDescription="@null"/>

            <View
                android:id="@+id/notificationDot"
                android:layout_width="7dp"
                android:layout_height="7dp"
                android:layout_gravity="top|end"
                android:layout_marginTop="5dp"
                android:layout_marginEnd="5dp"
                android:background="@drawable/bg_dot"/>

        </FrameLayout>

    </LinearLayout>

    <!-- ─── SCROLLABLE CONTENT ───────────────────────────────────────────── -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- ─── GREETING ─────────────────────────────────────────────── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="12dp"
                android:paddingBottom="6dp">

                <FrameLayout
                    android:layout_width="44dp"
                    android:layout_height="44dp">

                    <TextView
                        android:id="@+id/tvAvatarInitials"
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:background="@drawable/bg_avatar_gradient"
                        android:gravity="center"
                        android:textColor="@color/color_background"
                        android:textSize="15sp"
                        android:textStyle="bold"/>

                    <ImageView
                        android:id="@+id/ivAvatar"
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:background="@drawable/bg_avatar_gradient"
                        android:clipToOutline="true"
                        android:scaleType="centerCrop"
                        android:visibility="gone"
                        android:contentDescription="@null"/>

                </FrameLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="13dp"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tvGreeting"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/color_muted"
                        android:textSize="12.5sp"
                        android:textStyle="bold"/>

                    <TextView
                        android:id="@+id/tvUserName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="1dp"
                        android:textColor="@color/color_text_primary"
                        android:textSize="19sp"
                        android:textStyle="bold"
                        android:maxLines="1"
                        android:ellipsize="end"/>

                </LinearLayout>

            </LinearLayout>

            <!-- ─── FEATURE GRID ─────────────────────────────────────────── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="14dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="100dp"
                    android:orientation="horizontal">

                    <FrameLayout
                        android:id="@+id/blockClassroom"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:layout_marginEnd="6dp"
                        android:background="@drawable/bg_card"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?attr/selectableItemBackground">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:orientation="vertical"
                            android:padding="13dp">

                            <ImageView
                                android:id="@+id/ivClassroomIcon"
                                android:layout_width="30dp"
                                android:layout_height="30dp"
                                android:padding="6dp"
                                android:src="@drawable/ic_classroom"
                                android:contentDescription="@null"/>

                            <View
                                android:layout_width="0dp"
                                android:layout_height="0dp"
                                android:layout_weight="1"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/label_classroom"
                                android:textColor="@color/color_text_primary"
                                android:textSize="14sp"
                                android:textStyle="bold"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:text="@string/sub_classroom"
                                android:textColor="@color/color_muted"
                                android:textSize="10sp"/>

                        </LinearLayout>

                        <TextView
                            android:id="@+id/tvClassroomBadge"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="top|end"
                            android:layout_margin="10dp"
                            android:background="@drawable/bg_badge"
                            android:paddingStart="8dp"
                            android:paddingEnd="8dp"
                            android:paddingTop="3dp"
                            android:paddingBottom="3dp"
                            android:textSize="10sp"
                            android:textStyle="bold"/>

                    </FrameLayout>

                    <FrameLayout
                        android:id="@+id/blockCrew"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:layout_marginStart="6dp"
                        android:background="@drawable/bg_card"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?attr/selectableItemBackground">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:orientation="vertical"
                            android:padding="13dp">

                            <ImageView
                                android:id="@+id/ivCrewIcon"
                                android:layout_width="30dp"
                                android:layout_height="30dp"
                                android:padding="6dp"
                                android:src="@drawable/ic_crew"
                                android:contentDescription="@null"/>

                            <View
                                android:layout_width="0dp"
                                android:layout_height="0dp"
                                android:layout_weight="1"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/label_crew"
                                android:textColor="@color/color_text_primary"
                                android:textSize="14sp"
                                android:textStyle="bold"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:text="@string/sub_crew"
                                android:textColor="@color/color_muted"
                                android:textSize="10sp"/>

                        </LinearLayout>

                        <TextView
                            android:id="@+id/tvCrewBadge"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="top|end"
                            android:layout_margin="10dp"
                            android:background="@drawable/bg_badge"
                            android:paddingStart="8dp"
                            android:paddingEnd="8dp"
                            android:paddingTop="3dp"
                            android:paddingBottom="3dp"
                            android:textSize="10sp"
                            android:textStyle="bold"/>

                    </FrameLayout>

                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="100dp"
                    android:layout_marginTop="12dp"
                    android:orientation="horizontal">

                    <FrameLayout
                        android:id="@+id/blockLost"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:layout_marginEnd="6dp"
                        android:background="@drawable/bg_card"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?attr/selectableItemBackground">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:orientation="vertical"
                            android:padding="13dp">

                            <ImageView
                                android:id="@+id/ivLostIcon"
                                android:layout_width="30dp"
                                android:layout_height="30dp"
                                android:padding="6dp"
                                android:src="@drawable/ic_lost"
                                android:contentDescription="@null"/>

                            <View
                                android:layout_width="0dp"
                                android:layout_height="0dp"
                                android:layout_weight="1"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/label_lost"
                                android:textColor="@color/color_text_primary"
                                android:textSize="14sp"
                                android:textStyle="bold"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:text="@string/sub_lost"
                                android:textColor="@color/color_muted"
                                android:textSize="10sp"/>

                        </LinearLayout>

                        <TextView
                            android:id="@+id/tvLostBadge"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="top|end"
                            android:layout_margin="10dp"
                            android:background="@drawable/bg_badge"
                            android:paddingStart="8dp"
                            android:paddingEnd="8dp"
                            android:paddingTop="3dp"
                            android:paddingBottom="3dp"
                            android:textSize="10sp"
                            android:textStyle="bold"/>

                    </FrameLayout>

                    <FrameLayout
                        android:id="@+id/blockRoute"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:layout_marginStart="6dp"
                        android:background="@drawable/bg_card"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?attr/selectableItemBackground">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:orientation="vertical"
                            android:padding="13dp">

                            <ImageView
                                android:id="@+id/ivRouteIcon"
                                android:layout_width="30dp"
                                android:layout_height="30dp"
                                android:padding="6dp"
                                android:src="@drawable/ic_route"
                                android:contentDescription="@null"/>

                            <View
                                android:layout_width="0dp"
                                android:layout_height="0dp"
                                android:layout_weight="1"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/label_route"
                                android:textColor="@color/color_text_primary"
                                android:textSize="14sp"
                                android:textStyle="bold"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:text="@string/sub_route"
                                android:textColor="@color/color_muted"
                                android:textSize="10sp"/>

                        </LinearLayout>

                        <TextView
                            android:id="@+id/tvRouteBadge"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="top|end"
                            android:layout_margin="10dp"
                            android:background="@drawable/bg_badge"
                            android:paddingStart="8dp"
                            android:paddingEnd="8dp"
                            android:paddingTop="3dp"
                            android:paddingBottom="3dp"
                            android:textSize="10sp"
                            android:textStyle="bold"/>

                    </FrameLayout>

                </LinearLayout>

            </LinearLayout>

            <!-- ─── RECENT ACTIVITY ──────────────────────────────────────── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="18dp"
                android:paddingBottom="20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="8dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/label_recent_activity"
                        android:textColor="@color/color_muted"
                        android:textSize="10.5sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.1"/>

                    <View
                        android:layout_width="0dp"
                        android:layout_height="1dp"
                        android:layout_weight="1"
                        android:layout_marginStart="8dp"
                        android:background="@color/color_border"/>

                </LinearLayout>

                <LinearLayout
                    android:id="@+id/activityContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"/>

            </LinearLayout>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

</LinearLayout>
