<?xml version="1.0" encoding="utf-8"?>
<!--
    fragment_profile.xml  (UPDATED)
    ─────────────────────────────────
    Changes from original:
      1. Hero card:  pencil button (btnEditHero) added top-right,
                     overlapping the card like the HTML reference.
      2. About card: pencil button (btnEditAbout) in the section header row.
      3. Tab section: "+ Add" button (btnAddTabItem) next to the tab title row,
                     replaces full-screen EditProfileActivity navigation.
      4. Top bar: "Edit" button removed — editing is now done inline via sheets.

    View IDs that are NEW (wire in ProfileFragment.java):
      btnEditHero   → opens EditBasicInfoBottomSheet
      btnEditAbout  → opens EditBasicInfoBottomSheet (same sheet, both are about info)
      btnAddTabItem → opens Add sheet for the active tab
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/color_background"
    android:clipChildren="false"
    android:clipToPadding="false">

    <!-- ─── TOP BAR ──────────────────────────────────────────────────────── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:background="@color/color_background">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Campus Connect"
            android:textColor="@color/color_text_primary"
            android:textSize="18sp"
            android:textStyle="bold"/>

        <!-- Logout button (kept from original) -->
        <Button
            android:id="@+id/btnLogout"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:background="@drawable/bg_button_outline"
            android:text="Logout"
            android:textColor="@color/color_text_primary"
            android:textSize="11sp"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"/>

    </LinearLayout>

    <!-- ─── SCROLLABLE CONTENT ───────────────────────────────────────────── -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipChildren="false"
        android:clipToPadding="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:clipChildren="false"
            android:clipToPadding="false">

            <!-- ─── COVER BANNER ─────────────────────────────────────────── -->
            <View
                android:id="@+id/coverBanner"
                android:layout_width="match_parent"
                android:layout_height="100dp"/>

            <!-- ─── HERO CARD ─────────────────────────────────────────────── -->
            <!--
                Outer padding wrapper pulls the card up -32dp over the cover
                FrameLayout wraps the card + pencil button so the pencil can be
                positioned top-right of the card without interfering with layout.
            -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="-32dp"
                android:layout_marginStart="12dp"
                android:layout_marginEnd="12dp"
                android:clipChildren="false"
                android:clipToPadding="false">

                <!-- Card body -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@drawable/bg_card"
                    android:padding="16dp"
                    android:clipChildren="false"
                    android:clipToPadding="false">

                    <!-- Avatar row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:clipChildren="false"
                        android:clipToPadding="false">

                        <FrameLayout
                            android:layout_width="72dp"
                            android:layout_height="72dp"
                            android:layout_marginTop="-28dp"
                            android:clipChildren="false"
                            android:clipToPadding="false">

                            <ImageView
                                android:id="@+id/ivAvatar"
                                android:layout_width="72dp"
                                android:layout_height="72dp"
                                android:background="@drawable/bg_avatar_large"
                                android:scaleType="centerCrop"
                                android:clipToOutline="true"
                                android:src="@android:drawable/ic_menu_myplaces"/>

                        </FrameLayout>

                        <View
                            android:layout_width="0dp"
                            android:layout_height="1dp"
                            android:layout_weight="1"/>

                    </LinearLayout>

                    <!-- Full name -->
                    <TextView
                        android:id="@+id/tvFullName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/color_text_primary"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:layout_marginTop="10dp"/>

                    <!-- Username in cyan -->
                    <TextView
                        android:id="@+id/tvUsername"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/color_cyan"
                        android:textSize="13sp"
                        android:layout_marginTop="2dp"/>

                    <!-- User type badge -->
                    <TextView
                        android:id="@+id/tvUserType"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_badge"
                        android:textColor="@color/color_cyan"
                        android:textSize="11sp"
                        android:paddingStart="10dp"
                        android:paddingEnd="10dp"
                        android:paddingTop="4dp"
                        android:paddingBottom="4dp"
                        android:layout_marginTop="8dp"/>

                </LinearLayout>

                <!--
                    Pencil icon button — positioned top-right of the hero card.
                    Margin 12dp from top/right to sit inside the card corner.
                    Tapping opens EditBasicInfoBottomSheet.
                -->
                <TextView
                    android:id="@+id/btnEditHero"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_gravity="top|end"
                    android:layout_marginTop="12dp"
                    android:layout_marginEnd="12dp"
                    android:gravity="center"
                    android:text="✎"
                    android:textColor="@color/color_muted"
                    android:textSize="16sp"
                    android:background="@drawable/bg_input"
                    android:padding="0dp"/>

            </FrameLayout>

            <!-- ─── ABOUT SECTION ─────────────────────────────────────────── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_card"
                android:padding="16dp"
                android:layout_marginTop="10dp"
                android:layout_marginStart="12dp"
                android:layout_marginEnd="12dp">

                <!-- Section header row with pencil -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="8dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="ABOUT"
                        android:textColor="@color/color_muted"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.1"/>

                    <!-- Pencil edit button for About section -->
                    <TextView
                        android:id="@+id/btnEditAbout"
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:gravity="center"
                        android:text="✎"
                        android:textColor="@color/color_muted"
                        android:textSize="14sp"
                        android:background="@drawable/bg_input"
                        android:padding="0dp"/>

                </LinearLayout>

                <!-- Bio / about text -->
                <TextView
                    android:id="@+id/tvAbout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/color_text_body"
                    android:textSize="14sp"
                    android:lineSpacingMultiplier="1.5"/>

            </LinearLayout>

            <!-- ─── TAB SECTION ───────────────────────────────────────────── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="10dp"
                android:layout_marginStart="12dp"
                android:layout_marginEnd="12dp"
                android:layout_marginBottom="24dp">

                <!-- Tab buttons row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:orientation="horizontal"
                    android:background="@drawable/bg_card"
                    android:padding="4dp">

                    <TextView
                        android:id="@+id/tabProjects"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:text="Projects"
                        android:textSize="12sp"
                        android:textStyle="bold"/>

                    <TextView
                        android:id="@+id/tabExperience"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:text="Experience"
                        android:textSize="12sp"
                        android:textStyle="bold"/>

                    <TextView
                        android:id="@+id/tabEducation"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:text="Education"
                        android:textSize="12sp"
                        android:textStyle="bold"/>

                </LinearLayout>

                <!--
                    Sub-header row: active tab title on the left, "+ Add" on the right.
                    btnAddTabItem calls the right sheet depending on the active tab.
                -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="40dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="10dp">

                    <TextView
                        android:id="@+id/tvActiveTabTitle"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Projects"
                        android:textColor="@color/color_text_primary"
                        android:textSize="14sp"
                        android:textStyle="bold"/>

                    <!-- Plus add button -->
                    <TextView
                        android:id="@+id/btnAddTabItem"
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:gravity="center"
                        android:text="+"
                        android:textColor="@color/color_cyan"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:background="@drawable/bg_input"
                        android:padding="0dp"/>

                </LinearLayout>

                <!-- Tab content area -->
                <LinearLayout
                    android:id="@+id/tabContent"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"/>

            </LinearLayout>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

</LinearLayout>