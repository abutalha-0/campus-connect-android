<?xml version="1.0" encoding="utf-8"?>
<!--
    fragment_profile.xml  (UPDATED)
    ─────────────────────────────────
    Changes from original:
      1. Hero card:  pencil button (btnEditHero) added top-right,
                     overlapping the card like the HTML reference.
      2. About card: pencil button (btnEditAbout) in the section header row.
      3. Tab section: "+ Add" button (btnAddTabItem) next to the tab title row,
                     replaces full-screen EditProfileActivity navigation.
      4. Top bar: "Edit" button removed — editing is now done inline via sheets.

    View IDs that are NEW (wire in ProfileFragment.java):
      btnEditHero   → opens EditBasicInfoBottomSheet
      btnEditAbout  → opens EditBasicInfoBottomSheet (same sheet, both are about info)
      btnAddTabItem → opens Add sheet for the active tab
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/color_background"
    android:clipChildren="false"
    android:clipToPadding="false">

    <!--
        Hidden when viewing someone else's profile (PublicProfileActivity
        already shows its own back-button header) — see ProfileFragment.
    -->
    <include
        android:id="@+id/topBar"
        layout="@layout/top_bar_main"/>

    <!-- ─── SCROLLABLE CONTENT ───────────────────────────────────────────── -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipChildren="false"
        android:clipToPadding="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:clipChildren="false"
            android:clipToPadding="false">

            <!-- ─── COVER BANNER ─────────────────────────────────────────── -->
            <View
                android:id="@+id/coverBanner"
                android:layout_width="match_parent"
                android:layout_height="100dp"/>

            <!-- ─── HERO CARD ─────────────────────────────────────────────── -->
            <!--
                Outer padding wrapper pulls the card up -32dp over the cover
                FrameLayout wraps the card + pencil button so the pencil can be
                positioned top-right of the card without interfering with layout.
            -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="-32dp"
                android:layout_marginStart="12dp"
                android:layout_marginEnd="12dp"
                android:clipChildren="false"
                android:clipToPadding="false">

                <!-- Card body -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@drawable/bg_card"
                    android:padding="16dp"
                    android:clipChildren="false"
                    android:clipToPadding="false">

                    <!-- Avatar + info row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:clipChildren="false"
                        android:clipToPadding="false">

                        <FrameLayout
                            android:layout_width="64dp"
                            android:layout_height="64dp"
                            android:clipChildren="false"
                            android:clipToPadding="false">

                            <ImageView
                                android:id="@+id/ivAvatar"
                                android:layout_width="64dp"
                                android:layout_height="64dp"
                                android:background="@drawable/bg_avatar_large"
                                android:scaleType="centerCrop"
                                android:clipToOutline="true"
                                android:src="@android:drawable/ic_menu_myplaces"/>

                            <!--
                                Camera badge — small circular cyan button pinned to the
                                bottom-right corner of the avatar. Tapping it opens the
                                gallery photo picker (wired in ProfileFragment.java).
                            -->
                            <TextView
                                android:id="@+id/btnChangePhoto"
                                android:layout_width="22dp"
                                android:layout_height="22dp"
                                android:layout_gravity="bottom|end"
                                android:background="@drawable/bg_camera_badge"
                                android:gravity="center"
                                android:text="✎"
                                android:textColor="@color/color_background"
                                android:textSize="12sp"
                                android:padding="0dp"/>

                        </FrameLayout>

                        <!-- Name / username / type sit beside the avatar, not below it -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="14dp"
                            android:layout_marginEnd="36dp"
                            android:orientation="vertical">

                            <!-- Full name -->
                            <TextView
                                android:id="@+id/tvFullName"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:textColor="@color/color_text_primary"
                                android:textSize="18sp"
                                android:textStyle="bold"
                                android:maxLines="1"
                                android:ellipsize="end"/>

                            <!-- Username in cyan -->
                            <TextView
                                android:id="@+id/tvUsername"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:textColor="@color/color_cyan"
                                android:textSize="12.5sp"
                                android:maxLines="1"
                                android:ellipsize="end"
                                android:layout_marginTop="1dp"/>

                            <!-- User type pill -->
                            <TextView
                                android:id="@+id/tvUserType"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:background="@drawable/bg_tab_pill_active"
                                android:textColor="@color/color_cyan"
                                android:textSize="10sp"
                                android:textStyle="bold"
                                android:paddingStart="9dp"
                                android:paddingEnd="9dp"
                                android:paddingTop="3dp"
                                android:paddingBottom="3dp"
                                android:layout_marginTop="6dp"/>

                        </LinearLayout>

                    </LinearLayout>

                </LinearLayout>

                <!--
                    Pencil icon button — positioned top-right of the hero card.
                    Margin 12dp from top/right to sit inside the card corner.
                    Tapping opens EditBasicInfoBottomSheet.
                -->
                <TextView
                    android:id="@+id/btnEditHero"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_gravity="top|end"
                    android:layout_marginTop="12dp"
                    android:layout_marginEnd="12dp"
                    android:gravity="center"
                    android:text="✎"
                    android:textColor="@color/color_muted"
                    android:textSize="16sp"
                    android:background="@drawable/bg_input"
                    android:padding="0dp"/>

            </FrameLayout>

            <!-- ─── ABOUT SECTION ─────────────────────────────────────────── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_card"
                android:padding="16dp"
                android:layout_marginTop="10dp"
                android:layout_marginStart="12dp"
                android:layout_marginEnd="12dp">

                <!-- Section header row with pencil -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="8dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="ABOUT"
                        android:textColor="@color/color_muted"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.1"/>

                    <!-- Pencil edit button for About section -->
                    <TextView
                        android:id="@+id/btnEditAbout"
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:gravity="center"
                        android:text="✎"
                        android:textColor="@color/color_muted"
                        android:textSize="14sp"
                        android:background="@drawable/bg_input"
                        android:padding="0dp"/>

                </LinearLayout>

                <!-- Bio / about text -->
                <TextView
                    android:id="@+id/tvAbout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/color_text_body"
                    android:textSize="14sp"
                    android:lineSpacingMultiplier="1.5"/>

            </LinearLayout>

            <!-- ─── SKILLS SECTION ────────────────────────────────────────── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_card"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="13dp"
                android:paddingBottom="13dp"
                android:layout_marginTop="10dp"
                android:layout_marginStart="12dp"
                android:layout_marginEnd="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="8dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="SKILLS"
                        android:textColor="@color/color_muted"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.1"/>

                    <TextView
                        android:id="@+id/btnEditSkills"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:gravity="center"
                        android:text="✎"
                        android:textColor="@color/color_muted"
                        android:textSize="12sp"
                        android:background="@drawable/bg_input"
                        android:padding="0dp"/>

                </LinearLayout>

                <com.google.android.material.chip.ChipGroup
                    android:id="@+id/skillsChipGroup"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:chipSpacingHorizontal="6dp"
                    app:chipSpacingVertical="6dp"/>

            </LinearLayout>

            <!-- ─── CONNECT & NETWORK SECTION ─────────────────────────────── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_card"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="13dp"
                android:paddingBottom="13dp"
                android:layout_marginTop="10dp"
                android:layout_marginStart="12dp"
                android:layout_marginEnd="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="8dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="CONNECT &amp; NETWORK"
                        android:textColor="@color/color_muted"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.1"/>

                    <TextView
                        android:id="@+id/btnAddSocial"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:gravity="center"
                        android:text="✎"
                        android:textColor="@color/color_muted"
                        android:textSize="12sp"
                        android:background="@drawable/bg_input"
                        android:padding="0dp"/>

                </LinearLayout>

                <com.google.android.material.chip.ChipGroup
                    android:id="@+id/socialsChipGroup"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:chipSpacingHorizontal="6dp"
                    app:chipSpacingVertical="6dp"/>

            </LinearLayout>

            <!-- ─── TAB SECTION ───────────────────────────────────────────── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="10dp"
                android:layout_marginStart="12dp"
                android:layout_marginEnd="12dp"
                android:layout_marginBottom="24dp">

                <!-- Tab buttons row — each is its own rounded pill -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="32dp"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/tabProjects"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:layout_marginEnd="3dp"
                        android:gravity="center"
                        android:text="Projects"
                        android:textSize="11.5sp"
                        android:textStyle="bold"/>

                    <TextView
                        android:id="@+id/tabExperience"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:layout_marginStart="3dp"
                        android:layout_marginEnd="3dp"
                        android:gravity="center"
                        android:text="Experience"
                        android:textSize="11.5sp"
                        android:textStyle="bold"/>

                    <TextView
                        android:id="@+id/tabEducation"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:layout_marginStart="3dp"
                        android:gravity="center"
                        android:text="Education"
                        android:textSize="11.5sp"
                        android:textStyle="bold"/>

                </LinearLayout>

                <!--
                    Sub-header row: active tab title on the left, "+ Add" on the right.
                    btnAddTabItem calls the right sheet depending on the active tab.
                -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="40dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="10dp">

                    <TextView
                        android:id="@+id/tvActiveTabTitle"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Projects"
                        android:textColor="@color/color_text_primary"
                        android:textSize="14sp"
                        android:textStyle="bold"/>

                    <!-- Plus add button -->
                    <TextView
                        android:id="@+id/btnAddTabItem"
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:gravity="center"
                        android:text="+"
                        android:textColor="@color/color_cyan"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:background="@drawable/bg_input"
                        android:padding="0dp"/>

                </LinearLayout>

                <!-- Tab content area -->
                <LinearLayout
                    android:id="@+id/tabContent"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"/>

            </LinearLayout>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

</LinearLayout>