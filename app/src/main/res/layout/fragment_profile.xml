<?xml version="1.0" encoding="utf-8"?>
<!--
    ProfileFragment Layout
    ─────────────────────
    Structure:
    1. Top bar          → app name + logout button
    2. NestedScrollView → all scrollable content
       ├── Cover banner     → gradient strip
       ├── Hero card        → avatar + name + username + badge (overlaps cover)
       ├── About section    → bio/about text
       └── Tab section      → Projects / Experience / Education
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/color_background"
    android:clipChildren="false"
    android:clipToPadding="false">

    <!-- ─── TOP BAR ─────────────────────────────────────────────────────── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:background="@color/color_background">

        <!-- App name -->
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Campus"
            android:textColor="@color/color_text_primary"
            android:textSize="18sp"
            android:textStyle="bold"/>

        <!-- Logout button — subtle outline style, not primary action -->
        <Button
            android:id="@+id/btnLogout"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:background="@drawable/bg_button_outline"
            android:text="Logout"
            android:textColor="@color/color_muted"
            android:textSize="11sp"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"/>

    </LinearLayout>

    <!-- ─── SCROLLABLE CONTENT ───────────────────────────────────────────── -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipChildren="false"
        android:clipToPadding="false">

        <!-- Single child required by NestedScrollView -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:clipChildren="false"
            android:clipToPadding="false">

            <!-- ─── COVER BANNER ─────────────────────────────────────────── -->
            <!-- Gradient is applied programmatically in ProfileFragment.java -->
            <View
                android:id="@+id/coverBanner"
                android:layout_width="match_parent"
                android:layout_height="100dp"/>

            <!-- ─── HERO CARD ─────────────────────────────────────────────── -->
            <!--
                Negative marginTop pulls this card up over the cover banner
                creating the overlapping effect from the design
            -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:layout_marginTop="-32dp"
                android:clipChildren="false"
                android:clipToPadding="false">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@drawable/bg_card"
                    android:padding="16dp"
                    android:clipChildren="false"
                    android:clipToPadding="false">

                    <!-- Avatar row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:clipChildren="false"
                        android:clipToPadding="false">

                        <!--
                            Avatar FrameLayout
                            Negative marginTop pulls avatar up over the card top edge
                            giving the floating avatar effect from the design
                        -->
                        <FrameLayout
                            android:layout_width="72dp"
                            android:layout_height="72dp"
                            android:layout_marginTop="-28dp"
                            android:clipChildren="false"
                            android:clipToPadding="false">

                            <!--
                                Profile photo
                                - bg_avatar_large provides rounded corners
                                - clipToOutline clips the image to that shape
                                - outlineProvider is set in Java to make clipToOutline work
                                - Glide loads the Cloudinary URL at runtime
                                - Default icon shows before photo loads
                            -->
                            <ImageView
                                android:id="@+id/ivAvatar"
                                android:layout_width="72dp"
                                android:layout_height="72dp"
                                android:background="@drawable/bg_avatar_large"
                                android:scaleType="centerCrop"
                                android:clipToOutline="true"
                                android:src="@android:drawable/ic_menu_myplaces"/>

                        </FrameLayout>

                        <!-- Spacer pushes avatar to the left -->
                        <View
                            android:layout_width="0dp"
                            android:layout_height="1dp"
                            android:layout_weight="1"/>

                    </LinearLayout>

                    <!-- Full name -->
                    <TextView
                        android:id="@+id/tvFullName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/color_text_primary"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:layout_marginTop="10dp"/>

                    <!-- Username in cyan -->
                    <TextView
                        android:id="@+id/tvUsername"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/color_cyan"
                        android:textSize="13sp"
                        android:layout_marginTop="2dp"/>

                    <!-- User type badge e.g. STUDENT / CR -->
                    <TextView
                        android:id="@+id/tvUserType"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_badge"
                        android:textColor="@color/color_cyan"
                        android:textSize="11sp"
                        android:paddingStart="10dp"
                        android:paddingEnd="10dp"
                        android:paddingTop="4dp"
                        android:paddingBottom="4dp"
                        android:layout_marginTop="8dp"/>

                </LinearLayout>

            </LinearLayout>

            <!-- ─── ABOUT SECTION ─────────────────────────────────────────── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_card"
                android:padding="16dp"
                android:layout_marginTop="10dp"
                android:layout_marginStart="12dp"
                android:layout_marginEnd="12dp">

                <!-- Section label -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ABOUT"
                    android:textColor="@color/color_muted"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.1"
                    android:layout_marginBottom="8dp"/>

                <!-- Bio or about text populated from API -->
                <TextView
                    android:id="@+id/tvAbout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/color_text_body"
                    android:textSize="14sp"
                    android:lineSpacingMultiplier="1.5"/>

            </LinearLayout>

            <!-- ─── TAB SECTION ───────────────────────────────────────────── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="10dp"
                android:layout_marginStart="12dp"
                android:layout_marginEnd="12dp"
                android:layout_marginBottom="24dp">

                <!--
                    Tab buttons row
                    Active tab gets bg_tab_active background + cyan text
                    Inactive tabs get transparent background + muted text
                    Switching is handled in ProfileFragment.java → switchTab()
                -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:orientation="horizontal"
                    android:background="@drawable/bg_card"
                    android:padding="4dp">

                    <TextView
                        android:id="@+id/tabProjects"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:text="Projects"
                        android:textSize="12sp"
                        android:textStyle="bold"/>

                    <TextView
                        android:id="@+id/tabExperience"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:text="Experience"
                        android:textSize="12sp"
                        android:textStyle="bold"/>

                    <TextView
                        android:id="@+id/tabEducation"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:text="Education"
                        android:textSize="12sp"
                        android:textStyle="bold"/>

                </LinearLayout>

                <!--
                    Tab content container
                    Cards are inflated and added here dynamically in ProfileFragment.java
                    Content changes when user taps a tab button
                    item_project.xml / item_experience.xml / item_education.xml
                -->
                <LinearLayout
                    android:id="@+id/tabContent"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginTop="10dp"/>

            </LinearLayout>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

</LinearLayout>