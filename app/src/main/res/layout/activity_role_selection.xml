<?xml version="1.0" encoding="utf-8"?>
<!--
    "Who are you?" landing screen shown after onboarding. Student → Login,
    Faculty → coming-soon message (see RoleSelectionActivity).
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/color_background"
    android:paddingStart="28dp"
    android:paddingEnd="28dp"
    android:paddingTop="26dp"
    android:paddingBottom="32dp">

    <!-- ─── HEADER ───────────────────────────────────────────────────────── -->
    <ImageView
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:background="@drawable/bg_role_logo"
        android:padding="11dp"
        android:src="@drawable/ic_grad_cap"
        android:tint="#04121A"
        android:contentDescription="@null" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:text="@string/role_title"
        android:textColor="@color/color_text_primary"
        android:textSize="24sp"
        android:textStyle="bold"
        android:lineSpacingMultiplier="1.1" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="@string/role_subtitle"
        android:textColor="#73FFFFFF"
        android:textSize="13.5sp"
        android:lineSpacingMultiplier="1.5" />

    <!-- ─── ROLE CARDS (vertically centered) ─────────────────────────────── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center_vertical">

        <!-- Student -->
        <LinearLayout
            android:id="@+id/cardStudent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/bg_role_card"
            android:foreground="?attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true"
            android:padding="20dp">

            <FrameLayout
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:background="@drawable/bg_role_icon_cyan">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_student"
                    android:tint="@color/color_cyan"
                    android:contentDescription="@null" />
            </FrameLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="16dp"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/role_student_title"
                    android:textColor="@color/color_text_primary"
                    android:textSize="17sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="3dp"
                    android:text="@string/role_student_sub"
                    android:textColor="#73FFFFFF"
                    android:textSize="12sp"
                    android:lineSpacingMultiplier="1.4" />
            </LinearLayout>

            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:layout_marginStart="8dp"
                android:src="@drawable/ic_chevron_right"
                android:tint="#59FFFFFF"
                android:contentDescription="@null" />
        </LinearLayout>

        <!-- Faculty -->
        <LinearLayout
            android:id="@+id/cardFaculty"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/bg_role_card"
            android:foreground="?attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true"
            android:padding="20dp">

            <FrameLayout
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:background="@drawable/bg_role_icon_purple">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_grad_cap"
                    android:tint="@color/color_purple"
                    android:contentDescription="@null" />
            </FrameLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="16dp"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/role_faculty_title"
                    android:textColor="@color/color_text_primary"
                    android:textSize="17sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="3dp"
                    android:text="@string/role_faculty_sub"
                    android:textColor="#73FFFFFF"
                    android:textSize="12sp"
                    android:lineSpacingMultiplier="1.4" />
            </LinearLayout>

            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:layout_marginStart="8dp"
                android:src="@drawable/ic_chevron_right"
                android:tint="#59FFFFFF"
                android:contentDescription="@null" />
        </LinearLayout>

    </LinearLayout>

    <!-- ─── FOOTER ───────────────────────────────────────────────────────── -->
    <LinearLayout
        android:id="@+id/tvLogin"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:orientation="horizontal"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:clickable="true"
        android:focusable="true"
        android:padding="6dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/role_login_prompt"
            android:textColor="#59FFFFFF"
            android:textSize="12.5sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp"
            android:text="@string/role_login_action"
            android:textColor="@color/color_cyan"
            android:textSize="12.5sp"
            android:textStyle="bold" />

    </LinearLayout>

</LinearLayout>
