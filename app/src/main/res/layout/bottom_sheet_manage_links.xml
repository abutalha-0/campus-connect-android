<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_bottom_sheet"
    android:paddingBottom="32dp">

    <!-- Drag handle -->
    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="4dp"
        android:background="#3A4560"/>

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Connect &amp; Network"
            android:textColor="@color/color_text_primary"
            android:textSize="16sp"
            android:textStyle="bold"/>

        <TextView
            android:id="@+id/btnDone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Done"
            android:textColor="@color/color_cyan"
            android:textSize="14sp"
            android:textStyle="bold"
            android:padding="8dp"/>

    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/color_border"
        android:layout_marginBottom="20dp"/>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingEnd="20dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Your Links"
                android:textColor="@color/color_muted"
                android:textSize="11sp"
                android:textAllCaps="true"
                android:letterSpacing="0.08"
                android:layout_marginBottom="8dp"/>

            <com.google.android.material.chip.ChipGroup
                android:id="@+id/currentLinksChipGroup"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                app:chipSpacingHorizontal="6dp"
                app:chipSpacingVertical="6dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Platform"
                android:textColor="@color/color_muted"
                android:textSize="11sp"
                android:textAllCaps="true"
                android:letterSpacing="0.08"
                android:layout_marginBottom="6dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="32dp"
                android:orientation="horizontal"
                android:layout_marginBottom="8dp">

                <TextView
                    android:id="@+id/platformGithub"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:layout_marginEnd="3dp"
                    android:gravity="center"
                    android:text="GitHub"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:background="@drawable/bg_tab_pill_active"
                    android:textColor="@color/color_cyan"/>

                <TextView
                    android:id="@+id/platformLinkedin"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:layout_marginStart="3dp"
                    android:gravity="center"
                    android:text="LinkedIn"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:background="@drawable/bg_tab_pill_inactive"
                    android:textColor="@color/color_muted"/>

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="32dp"
                android:orientation="horizontal"
                android:layout_marginBottom="16dp">

                <TextView
                    android:id="@+id/platformFacebook"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:layout_marginEnd="3dp"
                    android:gravity="center"
                    android:text="Facebook"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:background="@drawable/bg_tab_pill_inactive"
                    android:textColor="@color/color_muted"/>

                <TextView
                    android:id="@+id/platformWebsite"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:layout_marginStart="3dp"
                    android:gravity="center"
                    android:text="Website"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:background="@drawable/bg_tab_pill_inactive"
                    android:textColor="@color/color_muted"/>

            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Profile URL"
                android:textColor="@color/color_muted"
                android:textSize="11sp"
                android:textAllCaps="true"
                android:letterSpacing="0.08"
                android:layout_marginBottom="6dp"/>

            <EditText
                android:id="@+id/etLinkUrl"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:background="@drawable/bg_input_selector"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:inputType="textUri"
                android:hint="https://github.com/yourname"
                android:textColor="@color/color_text_primary"
                android:textColorHint="@color/color_muted"
                android:textSize="14sp"
                android:layout_marginBottom="16dp"/>

            <TextView
                android:id="@+id/btnAddLink"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:gravity="center"
                android:text="+ Add Link"
                android:textColor="@color/color_background"
                android:textSize="14sp"
                android:textStyle="bold"
                android:background="@drawable/bg_button_primary"/>

        </LinearLayout>

    </ScrollView>

</LinearLayout>
