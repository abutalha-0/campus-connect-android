<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="230dp"
    android:layout_height="match_parent"
    android:layout_gravity="start"
    android:orientation="vertical"
    android:background="@color/color_card"
    android:paddingTop="24dp"
    android:paddingBottom="16dp"
    android:paddingStart="10dp"
    android:paddingEnd="10dp"
    android:elevation="8dp"
    android:fitsSystemWindows="true">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:paddingStart="10dp"
        android:paddingEnd="10dp"
        android:paddingBottom="12dp"
        android:text="MENU"
        android:textColor="@color/color_muted"
        android:textSize="10.5sp"
        android:textStyle="bold"
        android:letterSpacing="0.1"/>

    <LinearLayout
        android:id="@+id/drawerHome"
        style="@style/DrawerItem">
        <ImageView
            style="@style/DrawerItemIcon"
            android:src="@drawable/ic_nav_home"
            app:tint="@color/color_cyan"/>
        <TextView
            style="@style/DrawerItemLabel"
            android:text="@string/label_home"
            android:textColor="@color/color_cyan"/>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/drawerProfile"
        style="@style/DrawerItem">
        <ImageView
            style="@style/DrawerItemIcon"
            android:src="@drawable/ic_nav_profile"
            app:tint="@color/color_text_primary"/>
        <TextView
            style="@style/DrawerItemLabel"
            android:text="@string/label_profile"
            android:textColor="@color/color_text_primary"/>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/drawerSettings"
        style="@style/DrawerItem">
        <ImageView
            style="@style/DrawerItemIcon"
            android:src="@drawable/ic_settings"
            app:tint="@color/color_text_primary"/>
        <TextView
            style="@style/DrawerItemLabel"
            android:text="@string/label_settings"
            android:textColor="@color/color_text_primary"/>
    </LinearLayout>

    <View
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_weight="1"/>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginStart="10dp"
        android:layout_marginEnd="10dp"
        android:layout_marginBottom="8dp"
        android:background="@color/color_border"/>

    <LinearLayout
        android:id="@+id/drawerLogout"
        style="@style/DrawerItem">
        <ImageView
            style="@style/DrawerItemIcon"
            android:src="@drawable/ic_logout"
            app:tint="@color/color_red"/>
        <TextView
            style="@style/DrawerItemLabel"
            android:text="@string/btn_logout"
            android:textColor="@color/color_red"/>
    </LinearLayout>

</LinearLayout>
