<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="252dp"
    android:layout_height="match_parent"
    android:layout_gravity="start"
    android:orientation="vertical"
    android:background="@drawable/bg_drawer_panel"
    android:paddingTop="28dp"
    android:paddingBottom="16dp"
    android:paddingStart="12dp"
    android:paddingEnd="12dp"
    android:elevation="16dp">

    <!-- ─── PROFILE HEADER ───────────────────────────────────────────────── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:paddingBottom="18dp">

        <FrameLayout
            android:layout_width="56dp"
            android:layout_height="56dp">

            <TextView
                android:id="@+id/tvDrawerAvatarInitials"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:background="@drawable/bg_avatar_gradient"
                android:gravity="center"
                android:textColor="@color/color_background"
                android:textSize="18sp"
                android:textStyle="bold"/>

            <ImageView
                android:id="@+id/ivDrawerAvatar"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:background="@drawable/bg_avatar_gradient"
                android:clipToOutline="true"
                android:scaleType="centerCrop"
                android:visibility="gone"
                android:contentDescription="@null"/>

        </FrameLayout>

        <TextView
            android:id="@+id/tvDrawerName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:textColor="@color/color_text_primary"
            android:textSize="16sp"
            android:textStyle="bold"
            android:maxLines="1"
            android:ellipsize="end"/>

        <TextView
            android:id="@+id/tvDrawerSubtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:textColor="@color/color_cyan"
            android:textSize="12sp"
            android:maxLines="1"
            android:ellipsize="end"/>

    </LinearLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:paddingStart="10dp"
        android:paddingEnd="10dp"
        android:paddingBottom="12dp"
        android:text="MENU"
        android:textColor="@color/color_muted"
        android:textSize="10.5sp"
        android:textStyle="bold"
        android:letterSpacing="0.1"/>

    <LinearLayout
        android:id="@+id/drawerHome"
        style="@style/DrawerItem">
        <ImageView
            android:id="@+id/ivDrawerHomeIcon"
            style="@style/DrawerItemIcon"
            android:src="@drawable/ic_nav_home"
            app:tint="@color/color_cyan"/>
        <TextView
            android:id="@+id/tvDrawerHomeLabel"
            style="@style/DrawerItemLabel"
            android:text="@string/label_home"
            android:textColor="@color/color_cyan"/>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/drawerProfile"
        style="@style/DrawerItem">
        <ImageView
            android:id="@+id/ivDrawerProfileIcon"
            style="@style/DrawerItemIcon"
            android:src="@drawable/ic_nav_profile"
            app:tint="@color/color_text_primary"/>
        <TextView
            android:id="@+id/tvDrawerProfileLabel"
            style="@style/DrawerItemLabel"
            android:text="@string/label_profile"
            android:textColor="@color/color_text_primary"/>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/drawerSettings"
        style="@style/DrawerItem">
        <ImageView
            style="@style/DrawerItemIcon"
            android:src="@drawable/ic_settings"
            app:tint="@color/color_text_primary"/>
        <TextView
            style="@style/DrawerItemLabel"
            android:text="@string/label_settings"
            android:textColor="@color/color_text_primary"/>
    </LinearLayout>

    <View
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_weight="1"/>

    <View style="@style/DrawerDivider"/>

    <LinearLayout
        android:id="@+id/drawerLogout"
        style="@style/DrawerItem">
        <ImageView
            style="@style/DrawerItemIcon"
            android:src="@drawable/ic_logout"
            app:tint="@color/color_red"/>
        <TextView
            style="@style/DrawerItemLabel"
            android:text="@string/btn_logout"
            android:textColor="@color/color_red"/>
    </LinearLayout>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:gravity="center"
        android:text="@string/app_footer_tag"
        android:textColor="@color/color_border"
        android:textSize="10.5sp"
        android:textStyle="bold"
        android:letterSpacing="0.08"/>

</LinearLayout>
