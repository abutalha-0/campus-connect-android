<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_card"
    android:padding="14dp"
    android:layout_marginBottom="12dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/tvAvatar"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:background="@drawable/bg_avatar"
            android:foreground="?attr/selectableItemBackground"
            android:gravity="center"
            android:textColor="@color/color_text_primary"
            android:textSize="12sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginStart="10dp">

            <TextView
                android:id="@+id/tvAuthor"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="?attr/selectableItemBackground"
                android:maxLines="1"
                android:ellipsize="end"
                android:textColor="@color/color_text_primary"
                android:textSize="13sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvRole"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="7dp"
                android:background="@drawable/bg_resource_badge"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:paddingTop="2dp"
                android:paddingBottom="2dp"
                android:textSize="9.5sp"
                android:textStyle="bold"
                android:letterSpacing="0.04" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvDate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="6dp"
            android:textColor="@color/color_muted"
            android:textSize="11sp" />

        <TextView
            android:id="@+id/btnEdit"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:layout_marginStart="6dp"
            android:background="@drawable/bg_button_outline"
            android:gravity="center"
            android:text="✎"
            android:textColor="@color/color_muted"
            android:textSize="11sp"
            android:visibility="gone" />

        <TextView
            android:id="@+id/btnDelete"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:layout_marginStart="6dp"
            android:background="@drawable/bg_delete_button"
            android:gravity="center"
            android:text="🗑"
            android:textSize="11sp"
            android:visibility="gone" />
    </LinearLayout>

    <TextView
        android:id="@+id/tvText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:textColor="@color/color_text_body"
        android:textSize="13.5sp"
        android:lineSpacingMultiplier="1.4" />

    <!-- Optional highlighted callout -->
    <LinearLayout
        android:id="@+id/highlightBox"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@drawable/bg_info_banner"
        android:padding="10dp"
        android:layout_marginTop="10dp"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ⓘ"
            android:textColor="@color/color_cyan"
            android:textSize="14sp"
            android:layout_marginEnd="8dp" />

        <TextView
            android:id="@+id/tvHighlight"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/color_cyan"
            android:textSize="12.5sp"
            android:textStyle="bold" />
    </LinearLayout>
</LinearLayout>
