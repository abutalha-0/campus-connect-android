<?xml version="1.0" encoding="utf-8"?>
<!--
    bg_camera_badge.xml
    ─────────────────────
    Small circular cyan badge that sits on the bottom-right corner
    of the avatar. Holds the camera glyph (📷 or a vector icon).
-->
