<?xml version="1.0" encoding="utf-8"?>
<!--
    bg_input_selector.xml
    Swap between default and cyan-border focused states.
    Use this as android:background on every EditText.
-->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_focused="true"  android:drawable="@drawable/bg_input_focused"/>
    <item                               android:drawable="@drawable/bg_input"/>
</selector>